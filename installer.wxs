<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <Package
    Name="Equity Research Terminal"
    Manufacturer="Your Company"
    Version="1.0.0"
    UpgradeCode="12345678-1234-1234-1234-123456789000"
    Language="1033">

    <MediaTemplate />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="EquityResearchTerminal">

        <!-- MAIN EXE -->
        <Component Id="MainExe" Guid="*">
          <File Source="dist\EquityResearchTerminal\EquityResearchTerminal.exe" KeyPath="yes"/>
        </Component>

        <!-- INSTALL EVERYTHING ELSE -->
        <Directory Id="AppDir" Name="appfiles">

          <Component Id="AllFiles" Guid="*">

            <!-- WILDCARD INCLUDE -->
            <File Source="dist\EquityResearchTerminal\_internal\*"/>
            <File Source="dist\EquityResearchTerminal\modules\*"/>
            <File Source="dist\EquityResearchTerminal\models\*"/>

          </Component>

        </Directory>

      </Directory>
    </StandardDirectory>

    <!-- START MENU -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="AppShortcutDir" Name="Equity Research Terminal">

        <Component Id="ShortcutComponent" Guid="*">
          <Shortcut Id="AppShortcut"
                    Name="Equity Research Terminal"
                    Target="[INSTALLFOLDER]EquityResearchTerminal.exe"
                    WorkingDirectory="INSTALLFOLDER"/>
          <RemoveFolder Id="RemoveShortcutDir" On="uninstall"/>
          <RegistryValue Root="HKCU"
                         Key="Software\EquityResearchTerminal"
                         Name="installed"
                         Type="integer"
                         Value="1"
                         KeyPath="yes"/>
        </Component>

      </Directory>
    </StandardDirectory>

    <Feature Id="MainFeature" Title="Equity Research Terminal" Level="1">
      <ComponentRef Id="MainExe"/>
      <ComponentRef Id="AllFiles"/>
      <ComponentRef Id="ShortcutComponent"/>
    </Feature>

  </Package>

</Wix>